<h2 style="margin: 0 0 16px; font-size: 18px; font-weight: 600;">You have <%= @notifications.size %> new <%= "notification".pluralize(@notifications.size) %></h2>

<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin-bottom: 24px;">
  <% @notifications.each do |notification| %>
    <tr>
      <td style="padding: 12px 0; border-bottom: 1px solid #eee;">
        <p style="margin: 0 0 4px; font-size: 15px; color: #333;">
          <%= notification.message %>
        </p>
        <a href="<%= absolute_url(notification.url) %>" style="font-size: 13px; color: #4F46E5; text-decoration: none;">View details &rarr;</a>
      </td>
    </tr>
  <% end %>
</table>

<p style="margin: 0; font-size: 13px; color: #999;">
  You can change how often you receive these emails in your profile settings.
</p>
